node_modules/
out/
dist/
*.vsix
.vscode-test/
__pycache__/

# Transient release-notes file written by scripts/publish.py.
.release-notes-*.md

# Generated copies of the repo-root README.md / CHANGELOG.md, regenerated by
# scripts/publish.py (sync_extension_docs) at package time. The root files are
# the single source of truth; edit those, never these copies.
extension/README.md
extension/CHANGELOG.md

# Private working note, not for the public repo.
bugs/FINISH_GUIDE.md

# Saropa Log Capture: ignore generated report output, but keep the
# organizer script (durable tooling, not generated).
reports/*
!reports/organize_reports.py

# Saropa Suite diagnostics/index cache: machine-generated, per-run churn
# (timestamps, buildTime, trigram search indexes). Not source.
.saropa/

# Project-scoped pin store: holds whatever paths the user pins, which can be
# sensitive file names. Never publish it.
.vscode/saropa-workspace.json
