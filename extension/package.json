          "when": "false"
        },
        {
          "command": "saropaWorkspace.peekPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.peekFocusedPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.toggleTail",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.runPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.runPinNow",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.runPinLastParams",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureRun",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.simulateRun",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.diffLastRuns",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.useAsTemplate",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.copyPinLink",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureSchedule",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureTriggers",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureAppearance",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.renamePin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.unpin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.pinFile",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.pinFileGlobal",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.addProjectPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.removeProjectPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.addGlobalPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.removeGlobalPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.renameGroup",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.deleteGroup",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.revealNextScheduled",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.runPinById",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.promoteRecipe",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.forceKillPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.recipe.snapshotProcesses",
          "when": "false"
        }
      ]
    },
    "configuration": [
      {
        "title": "%extension.displayName%",
        "properties": {
          "saropaWorkspace.autoPins.patterns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "pubspec.yaml",
              "analysis_options.yaml"
            ],
            "description": "%config.autoPins.patterns.description%"
          },
          "saropaWorkspace.doubleClickMs": {
            "type": "number",
            "default": 400,
            "minimum": 150,
            "maximum": 1000,
            "description": "%config.doubleClickMs.description%"
          },
          "saropaWorkspace.previewMode.enabled": {
            "type": "boolean",
            "default": false,
            "description": "%config.previewMode.enabled.description%"
          },
          "saropaWorkspace.defaultUseIntegratedTerminal": {
            "type": "boolean",
            "default": true,
            "description": "%config.defaultUseIntegratedTerminal.description%"
          },
          "saropaWorkspace.terminalName": {
            "type": "string",
            "default": "Saropa Workspace",
            "description": "%config.terminalName.description%"
          },
          "saropaWorkspace.suggestions.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.suggestions.enabled.description%"
          },
          "saropaWorkspace.suggestions.openThreshold": {
            "type": "number",
            "default": 6,
            "minimum": 3,
            "maximum": 50,
            "description": "%config.suggestions.openThreshold.description%"
          },
          "saropaWorkspace.recipes.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.recipes.enabled.description%"
          },
          "saropaWorkspace.aiContext.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.aiContext.enabled.description%"
          },
          "saropaWorkspace.aiContext.claudeChatFolders": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              ".claude",
              ".cline/tasks",
              "docs/chats"
            ],
            "description": "%config.aiContext.claudeChatFolders.description%"
          },
          "saropaWorkspace.telemetry.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.telemetry.enabled.description%"
          },
          "saropaWorkspace.interpreterDefaults": {
            "type": "object",
            "default": {
              ".py": "python",
              ".js": "node",
              ".mjs": "node",
              ".cjs": "node",
              ".ts": "ts-node",
              ".ps1": "pwsh -File",
              ".sh": "bash",
              ".rb": "ruby"
            },
            "additionalProperties": {
              "type": "string"
            },
            "description": "%config.interpreterDefaults.description%"
          },
          "saropaWorkspace.projectFiles.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.projectFiles.enabled.description%"
          },
          "saropaWorkspace.projectFiles.files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "README.md",
              "CHANGELOG.md",
              "ROADMAP.md",
              "CONTRIBUTING.md",
              "SECURITY.md",
              "LICENSE",
              "LICENSE.md",
              "package.json",
              "pubspec.yaml",
              "Cargo.toml",
              "pyproject.toml",
              "go.mod"
            ],
            "description": "%config.projectFiles.files.description%"
          },
          "saropaWorkspace.processMonitor.heartbeat.enabled": {
            "type": "boolean",
            "default": false,
            "description": "%config.processMonitor.heartbeat.enabled.description%"
          },
          "saropaWorkspace.processMonitor.heartbeat.intervalMinutes": {
            "type": "number",
            "default": 15,
            "minimum": 1,
            "maximum": 240,
            "description": "%config.processMonitor.heartbeat.intervalMinutes.description%"
          },
          "saropaWorkspace.processMonitor.ramCeilingMB": {
            "type": "number",
            "default": 4096,
            "minimum": 128,
            "description": "%config.processMonitor.ramCeilingMB.description%"
          },
          "saropaWorkspace.processMonitor.helperCountCeiling": {
            "type": "number",
            "default": 200,
            "minimum": 10,
            "description": "%config.processMonitor.helperCountCeiling.description%"
          },
          "saropaWorkspace.hygiene.mode": {
            "type": "string",
            "enum": [
              "empty",
              "oversized",
              "both"
            ],
            "default": "both",
            "description": "%config.hygiene.mode.description%"
          },
          "saropaWorkspace.hygiene.fileMaxMB": {
            "type": "number",
            "default": 100,
            "minimum": 1,
            "description": "%config.hygiene.fileMaxMB.description%"
          },
          "saropaWorkspace.hygiene.folderMaxMB": {
            "type": "number",
            "default": 1024,
            "minimum": 1,
            "description": "%config.hygiene.folderMaxMB.description%"
          },
          "saropaWorkspace.hygiene.fileMinMB": {
            "type": "number",
            "default": 0,
            "minimum": 0,
            "description": "%config.hygiene.fileMinMB.description%"
          },
          "saropaWorkspace.hygiene.respectGitignore": {
            "type": "boolean",
            "default": true,
            "description": "%config.hygiene.respectGitignore.description%"
          },
          "saropaWorkspace.hygiene.exclude": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "%config.hygiene.exclude.description%"
          },
          "saropaWorkspace.sound.enabled": {
            "type": "boolean",
            "default": false,
            "description": "%config.sound.enabled.description%"
          },
          "saropaWorkspace.sound.onStart": {
            "type": "boolean",
            "default": false,
            "description": "%config.sound.onStart.description%"
          },
          "saropaWorkspace.sound.onSuccess": {
            "type": "boolean",
            "default": true,
            "description": "%config.sound.onSuccess.description%"
          },
          "saropaWorkspace.sound.onFailure": {
            "type": "boolean",
            "default": true,
            "description": "%config.sound.onFailure.description%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "check-types": "tsc -p ./ --noEmit",
    "lint": "tsc -p ./ --noEmit",
    "watch": "node esbuild.js --watch",
    "build": "node esbuild.js",
    "package": "node esbuild.js --production",
    "test": "node esbuild.js && node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
