{
  "name": "saropa-workspace",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "saropa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saropa/saropa_workspace"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "favorites",
    "pin",
    "shortcuts",
    "scripts",
    "run",
    "saropa"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saropaWorkspace",
          "title": "%views.container.title%",
          "icon": "sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "saropaWorkspace": [
        {
          "id": "saropaWorkspace.pins",
          "name": "%views.pins.name%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "saropaWorkspace.pins",
        "contents": "%viewsWelcome.pins.contents%"
      }
    ],
    "commands": [
      {
        "command": "saropaWorkspace.refresh",
        "title": "%command.refresh.title%",
        "category": "%extension.displayName%",
        "icon": "$(refresh)"
      },
      {
        "command": "saropaWorkspace.pinActiveFile",
        "title": "%command.pinActiveFile.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.pinActiveFileGlobal",
        "title": "%command.pinActiveFileGlobal.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.pinFile",
        "title": "%command.pinFile.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.pinFileGlobal",
        "title": "%command.pinFileGlobal.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.activatePin",
        "title": "%command.activatePin.title%"
      },
      {
        "command": "saropaWorkspace.openPin",
        "title": "%command.openPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaWorkspace.runPin",
        "title": "%command.runPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(play)"
      },
      {
        "command": "saropaWorkspace.stopPin",
        "title": "%command.stopPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(debug-stop)"
      },
      {
        "command": "saropaWorkspace.configureRun",
        "title": "%command.configureRun.title%",
        "category": "%extension.displayName%",
        "icon": "$(gear)"
      },
      {
        "command": "saropaWorkspace.configureSchedule",
        "title": "%command.configureSchedule.title%",
        "category": "%extension.displayName%",
        "icon": "$(clock)"
      },
      {
        "command": "saropaWorkspace.renamePin",
        "title": "%command.renamePin.title%",
        "category": "%extension.displayName%",
        "icon": "$(edit)"
      },
      {
        "command": "saropaWorkspace.unpin",
        "title": "%command.unpin.title%",
        "category": "%extension.displayName%",
        "icon": "$(close)"
      },
      {
        "command": "saropaWorkspace.restoreAutoPins",
        "title": "%command.restoreAutoPins.title%",
        "category": "%extension.displayName%",
        "icon": "$(history)"
      },
      {
        "command": "saropaWorkspace.importFavorites",
        "title": "%command.importFavorites.title%",
        "category": "%extension.displayName%",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "saropaWorkspace.refresh",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@1"
        },
        {
          "command": "saropaWorkspace.restoreAutoPins",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@2"
        },
        {
          "command": "saropaWorkspace.importFavorites",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@1"
        }
      ],
      "view/item/context": [
        {
          "command": "saropaWorkspace.runPin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/ && viewItem != pinRunning",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "view == saropaWorkspace.pins && viewItem == pinRunning",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.unpin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/",
          "group": "inline@2"
        },
        {
          "command": "saropaWorkspace.openPin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/",
          "group": "1_actions@1"
        },
        {
          "command": "saropaWorkspace.runPin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/ && viewItem != pinRunning",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "view == saropaWorkspace.pins && viewItem == pinRunning",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.configureRun",
          "when": "view == saropaWorkspace.pins && viewItem == pin",
          "group": "2_edit@1"
        },
        {
          "command": "saropaWorkspace.configureSchedule",
          "when": "view == saropaWorkspace.pins && viewItem == pin",
          "group": "2_edit@2"
        },
        {
          "command": "saropaWorkspace.renamePin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/",
          "group": "2_edit@3"
        },
        {
          "command": "saropaWorkspace.unpin",
          "when": "view == saropaWorkspace.pins && viewItem =~ /^pin/",
          "group": "2_edit@4"
        }
      ],
      "explorer/context": [
        {
          "command": "saropaWorkspace.pinFile",
          "group": "saropa@1"
        },
        {
          "command": "saropaWorkspace.pinFileGlobal",
          "group": "saropa@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "saropaWorkspace.pinActiveFile",
          "group": "saropa@1"
        }
      ],
      "commandPalette": [
        {
          "command": "saropaWorkspace.activatePin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.openPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.runPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureRun",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.configureSchedule",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.renamePin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.unpin",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.pinFile",
          "when": "false"
        },
        {
          "command": "saropaWorkspace.pinFileGlobal",
          "when": "false"
        }
      ]
    },
    "configuration": [
      {
        "title": "%extension.displayName%",
        "properties": {
          "saropaWorkspace.autoPins.patterns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "pubspec.yaml",
              "analysis_options.yaml"
            ],
            "description": "%config.autoPins.patterns.description%"
          },
          "saropaWorkspace.doubleClickMs": {
            "type": "number",
            "default": 400,
            "minimum": 150,
            "maximum": 1000,
            "description": "%config.doubleClickMs.description%"
          },
          "saropaWorkspace.defaultUseIntegratedTerminal": {
            "type": "boolean",
            "default": true,
            "description": "%config.defaultUseIntegratedTerminal.description%"
          },
          "saropaWorkspace.terminalName": {
            "type": "string",
            "default": "Saropa Workspace",
            "description": "%config.terminalName.description%"
          },
          "saropaWorkspace.interpreterDefaults": {
            "type": "object",
            "default": {
              ".py": "python",
              ".js": "node",
              ".mjs": "node",
              ".cjs": "node",
              ".ts": "ts-node",
              ".ps1": "pwsh -File",
              ".sh": "bash",
              ".rb": "ruby"
            },
            "additionalProperties": {
              "type": "string"
            },
            "description": "%config.interpreterDefaults.description%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "check-types": "tsc -p ./ --noEmit",
    "lint": "tsc -p ./ --noEmit",
    "watch": "node esbuild.js --watch",
    "build": "node esbuild.js",
    "package": "node esbuild.js --production",
    "test": "node esbuild.js && node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
