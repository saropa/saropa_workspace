{
  "name": "saropa-workspace",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.1",
  "publisher": "saropa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saropa/saropa_workspace"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "favorites",
    "pin",
    "shortcuts",
    "scripts",
    "run",
    "saropa"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saropaWorkspace",
          "title": "%views.container.title%",
          "icon": "sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "saropaWorkspace": [
        {
          "id": "saropaWorkspace.pins",
          "name": "%views.pins.name%"
        },
        {
          "id": "saropaWorkspace.recipes",
          "name": "%views.recipes.name%"
        },
        {
          "id": "saropaWorkspace.projectFiles",
          "name": "%views.projectFiles.name%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "saropaWorkspace.pins",
        "contents": "%viewsWelcome.pins.contents%"
      },
      {
        "view": "saropaWorkspace.recipes",
        "contents": "%viewsWelcome.recipes.contents%"
      },
      {
        "view": "saropaWorkspace.projectFiles",
        "contents": "%viewsWelcome.projectFiles.contents%"
      }
    ],
    "commands": [
      {
        "command": "saropaWorkspace.refresh",
        "title": "%command.refresh.title%",
        "category": "%extension.displayName%",
        "icon": "$(refresh)"
      },
      {
        "command": "saropaWorkspace.refreshProjectFiles",
        "title": "%command.refreshProjectFiles.title%",
        "category": "%extension.displayName%",
        "icon": "$(refresh)"
      },
      {
        "command": "saropaWorkspace.copyPath",
        "title": "%command.copyPath.title%",
        "category": "%extension.displayName%",
        "icon": "$(copy)"
      },
      {
        "command": "saropaWorkspace.runAnyPin",
        "title": "%command.runAnyPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(run-all)"
      },
      {
        "command": "saropaWorkspace.runPinWithOverrides",
        "title": "%command.runPinWithOverrides.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.resetRunHistory",
        "title": "%command.resetRunHistory.title%",
        "category": "%extension.displayName%",
        "icon": "$(clear-all)"
      },
      {
        "command": "saropaWorkspace.newScratchpad",
        "title": "%command.newScratchpad.title%",
        "category": "%extension.displayName%",
        "icon": "$(notebook)"
      },
      {
        "command": "saropaWorkspace.saveLayout",
        "title": "%command.saveLayout.title%",
        "category": "%extension.displayName%",
        "icon": "$(editor-layout)"
      },
      {
        "command": "saropaWorkspace.restoreLayout",
        "title": "%command.restoreLayout.title%",
        "category": "%extension.displayName%",
        "icon": "$(editor-layout)"
      },
      {
        "command": "saropaWorkspace.pinActiveFile",
        "title": "%command.pinActiveFile.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.pinActiveFileGlobal",
        "title": "%command.pinActiveFileGlobal.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.pinToLine",
        "title": "%command.pinToLine.title%",
        "category": "%extension.displayName%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaWorkspace.pinFile",
        "title": "%command.pinFile.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.pinFileGlobal",
        "title": "%command.pinFileGlobal.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.addProjectPin",
        "title": "%command.addProjectPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.removeProjectPin",
        "title": "%command.removeProjectPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(pinned)"
      },
      {
        "command": "saropaWorkspace.addGlobalPin",
        "title": "%command.addGlobalPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(globe)"
      },
      {
        "command": "saropaWorkspace.removeGlobalPin",
        "title": "%command.removeGlobalPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(globe)"
      },
      {
        "command": "saropaWorkspace.activatePin",
        "title": "%command.activatePin.title%"
      },
      {
        "command": "saropaWorkspace.openPin",
        "title": "%command.openPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaWorkspace.runPin",
        "title": "%command.runPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(play)"
      },
      {
        "command": "saropaWorkspace.runPinNow",
        "title": "%command.runPinNow.title%",
        "category": "%extension.displayName%",
        "icon": "$(play)"
      },
      {
        "command": "saropaWorkspace.peekPin",
        "title": "%command.peekPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(eye)"
      },
      {
        "command": "saropaWorkspace.toggleTail",
        "title": "%command.toggleTail.title%",
        "category": "%extension.displayName%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "saropaWorkspace.peekFocusedPin",
        "title": "%command.peekFocusedPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(eye)"
      },
      {
        "command": "saropaWorkspace.runPinLastParams",
        "title": "%command.runPinLastParams.title%",
        "category": "%extension.displayName%",
        "icon": "$(run-all)"
      },
      {
        "command": "saropaWorkspace.stopPin",
        "title": "%command.stopPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(debug-stop)"
      },
      {
        "command": "saropaWorkspace.forceKillPin",
        "title": "%command.forceKillPin.title%",
        "category": "%extension.displayName%",
        "icon": "$(trash)"
      },
      {
        "command": "saropaWorkspace.configureRun",
        "title": "%command.configureRun.title%",
        "category": "%extension.displayName%",
        "icon": "$(gear)"
      },
      {
        "command": "saropaWorkspace.simulateRun",
        "title": "%command.simulateRun.title%",
        "category": "%extension.displayName%",
        "icon": "$(beaker)"
      },
      {
        "command": "saropaWorkspace.diffLastRuns",
        "title": "%command.diffLastRuns.title%",
        "category": "%extension.displayName%",
        "icon": "$(diff)"
      },
      {
        "command": "saropaWorkspace.useAsTemplate",
        "title": "%command.useAsTemplate.title%",
        "category": "%extension.displayName%",
        "icon": "$(files)"
      },
      {
        "command": "saropaWorkspace.copyPinLink",
        "title": "%command.copyPinLink.title%",
        "category": "%extension.displayName%",
        "icon": "$(link)"
      },
      {
        "command": "saropaWorkspace.pinExternalFile",
        "title": "%command.pinExternalFile.title%",
        "category": "%extension.displayName%",
        "icon": "$(globe)"
      },
      {
        "command": "saropaWorkspace.configureSchedule",
        "title": "%command.configureSchedule.title%",
        "category": "%extension.displayName%",
        "icon": "$(clock)"
      },
      {
        "command": "saropaWorkspace.configureTriggers",
        "title": "%command.configureTriggers.title%",
        "category": "%extension.displayName%",
        "icon": "$(git-merge)"
      },
      {
        "command": "saropaWorkspace.openPlanner",
        "title": "%command.openPlanner.title%",
        "category": "%extension.displayName%",
        "icon": "$(calendar)"
      },
      {
        "command": "saropaWorkspace.configureAppearance",
        "title": "%command.configureAppearance.title%",
        "category": "%extension.displayName%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "saropaWorkspace.renamePin",
        "title": "%command.renamePin.title%",
        "category": "%extension.displayName%",
        "icon": "$(edit)"
      },
      {
        "command": "saropaWorkspace.unpin",
        "title": "%command.unpin.title%",
        "category": "%extension.displayName%",
        "icon": "$(close)"
      },
      {
        "command": "saropaWorkspace.restoreAutoPins",
        "title": "%command.restoreAutoPins.title%",
        "category": "%extension.displayName%",
        "icon": "$(history)"
      },
      {
        "command": "saropaWorkspace.importFavorites",
        "title": "%command.importFavorites.title%",
        "category": "%extension.displayName%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "saropaWorkspace.scanSiblingFavorites",
        "title": "%command.scanSiblingFavorites.title%",
        "category": "%extension.displayName%",
        "icon": "$(search)"
      },
      {
        "command": "saropaWorkspace.exportPins",
        "title": "%command.exportPins.title%",
        "category": "%extension.displayName%",
        "icon": "$(export)"
      },
      {
        "command": "saropaWorkspace.importPins",
        "title": "%command.importPins.title%",
        "category": "%extension.displayName%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "saropaWorkspace.editPinsConfig",
        "title": "%command.editPinsConfig.title%",
        "category": "%extension.displayName%",
        "icon": "$(json)"
      },
      {
        "command": "saropaWorkspace.showRunAnalytics",
        "title": "%command.showRunAnalytics.title%",
        "category": "%extension.displayName%",
        "icon": "$(graph)"
      },
      {
        "command": "saropaWorkspace.configureBootSequence",
        "title": "%command.configureBootSequence.title%",
        "category": "%extension.displayName%",
        "icon": "$(rocket)"
      },
      {
        "command": "saropaWorkspace.runBootSequence",
        "title": "%command.runBootSequence.title%",
        "category": "%extension.displayName%",
        "icon": "$(run-all)"
      },
      {
        "command": "saropaWorkspace.showOutput",
        "title": "%command.showOutput.title%",
        "category": "%extension.displayName%",
        "icon": "$(output)"
      },
      {
        "command": "saropaWorkspace.addGroup",
        "title": "%command.addGroup.title%",
        "category": "%extension.displayName%",
        "icon": "$(new-folder)"
      },
      {
        "command": "saropaWorkspace.renameGroup",
        "title": "%command.renameGroup.title%",
        "category": "%extension.displayName%",
        "icon": "$(edit)"
      },
      {
        "command": "saropaWorkspace.deleteGroup",
        "title": "%command.deleteGroup.title%",
        "category": "%extension.displayName%",
        "icon": "$(trash)"
      },
      {
        "command": "saropaWorkspace.revealNextScheduled",
        "title": "%command.revealNextScheduled.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runPinById",
        "title": "%command.runPinById.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runTopPin1",
        "title": "%command.runTopPin1.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runTopPin2",
        "title": "%command.runTopPin2.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runTopPin3",
        "title": "%command.runTopPin3.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runTopPin4",
        "title": "%command.runTopPin4.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.runTopPin5",
        "title": "%command.runTopPin5.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.promoteRecipe",
        "title": "%command.promoteRecipe.title%",
        "category": "%extension.displayName%",
        "icon": "$(pin)"
      },
      {
        "command": "saropaWorkspace.restoreRecipes",
        "title": "%command.restoreRecipes.title%",
        "category": "%extension.displayName%",
        "icon": "$(history)"
      },
      {
        "command": "saropaWorkspace.recipe.setupEnv",
        "title": "%command.recipe.setupEnv.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.recipe.openConfigFiles",
        "title": "%command.recipe.openConfigFiles.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.recipe.copyVersion",
        "title": "%command.recipe.copyVersion.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.recipe.runNearestScript",
        "title": "%command.recipe.runNearestScript.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.openProcessMonitor",
        "title": "%command.openProcessMonitor.title%",
        "category": "%extension.displayName%",
        "icon": "$(pulse)"
      },
      {
        "command": "saropaWorkspace.recipe.snapshotProcesses",
        "title": "%command.recipe.snapshotProcesses.title%",
        "category": "%extension.displayName%"
      },
      {
        "command": "saropaWorkspace.recipe.runHygieneScan",
        "title": "%command.recipe.runHygieneScan.title%",
        "category": "%extension.displayName%",
        "icon": "$(search)"
      }
    ],
    "submenus": [
      {
        "id": "saropaWorkspace.pinSubmenu",
        "label": "%submenu.workspacePin.label%",
        "icon": "$(pin)"
      }
    ],
    "keybindings": [
      {
        "command": "saropaWorkspace.peekFocusedPin",
        "key": "alt+p",
        "mac": "alt+p",
        "when": "focusedView == saropaWorkspace.pins"
      }
    ],
    "menus": {
      "saropaWorkspace.pinSubmenu": [
        {
          "command": "saropaWorkspace.addProjectPin",
          "when": "resourcePath not in saropaWorkspace.projectPinnedPaths",
          "group": "1_project@1"
        },
        {
          "command": "saropaWorkspace.removeProjectPin",
          "when": "resourcePath in saropaWorkspace.projectPinnedPaths",
          "group": "1_project@2"
        },
        {
          "command": "saropaWorkspace.addGlobalPin",
          "when": "resourcePath not in saropaWorkspace.globalPinnedPaths",
          "group": "2_global@1"
        },
        {
          "command": "saropaWorkspace.removeGlobalPin",
          "when": "resourcePath in saropaWorkspace.globalPinnedPaths",
          "group": "2_global@2"
        }
      ],
      "view/title": [
        {
          "command": "saropaWorkspace.runAnyPin",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@1"
        },
        {
          "command": "saropaWorkspace.openPlanner",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@2"
        },
        {
          "command": "saropaWorkspace.addGroup",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@3"
        },
        {
          "command": "saropaWorkspace.refresh",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@4"
        },
        {
          "command": "saropaWorkspace.restoreAutoPins",
          "when": "view == saropaWorkspace.pins",
          "group": "navigation@5"
        },
        {
          "command": "saropaWorkspace.newScratchpad",
          "when": "view == saropaWorkspace.pins",
          "group": "0_new@1"
        },
        {
          "command": "saropaWorkspace.saveLayout",
          "when": "view == saropaWorkspace.pins",
          "group": "0_new@2"
        },
        {
          "command": "saropaWorkspace.restoreLayout",
          "when": "view == saropaWorkspace.pins",
          "group": "0_new@3"
        },
        {
          "command": "saropaWorkspace.pinExternalFile",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@0"
        },
        {
          "command": "saropaWorkspace.importFavorites",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@1"
        },
        {
          "command": "saropaWorkspace.scanSiblingFavorites",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@2"
        },
        {
          "command": "saropaWorkspace.exportPins",
          "when": "view == saropaWorkspace.pins",
          "group": "2_share@1"
        },
        {
          "command": "saropaWorkspace.importPins",
          "when": "view == saropaWorkspace.pins",
          "group": "2_share@2"
        },
        {
          "command": "saropaWorkspace.editPinsConfig",
          "when": "view == saropaWorkspace.pins",
          "group": "2_share@3"
        },
        {
          "command": "saropaWorkspace.showOutput",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@3"
        },
        {
          "command": "saropaWorkspace.showRunAnalytics",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@4"
        },
        {
          "command": "saropaWorkspace.resetRunHistory",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@5"
        },
        {
          "command": "saropaWorkspace.configureBootSequence",
          "when": "view == saropaWorkspace.pins",
          "group": "1_more@6"
        },
        {
          "command": "saropaWorkspace.restoreRecipes",
          "when": "view == saropaWorkspace.recipes",
          "group": "navigation@1"
        },
        {
          "command": "saropaWorkspace.refreshProjectFiles",
          "when": "view == saropaWorkspace.projectFiles",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "saropaWorkspace.resetRunHistory",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == recentRoot",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.showRunAnalytics",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == recentRoot",
          "group": "1_actions@1"
        },
        {
          "command": "saropaWorkspace.resetRunHistory",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == recentRoot",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.promoteRecipe",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pinRecipe || viewItem == pinRecipeScheduled)",
          "group": "inline@0"
        },
        {
          "command": "saropaWorkspace.promoteRecipe",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pinRecipe || viewItem == pinRecipeScheduled)",
          "group": "2_edit@1"
        },
        {
          "command": "saropaWorkspace.addGroup",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == scopeRoot",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.addGroup",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == scopeRoot",
          "group": "1_actions@1"
        },
        {
          "command": "saropaWorkspace.renameGroup",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == userGroup",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.renameGroup",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == userGroup",
          "group": "1_actions@1"
        },
        {
          "command": "saropaWorkspace.deleteGroup",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == userGroup",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.runPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/ && viewItem != pinRunning && viewItem != pinStopping",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == pinRunning",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.forceKillPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == pinStopping",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.unpin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "inline@2"
        },
        {
          "command": "saropaWorkspace.openPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "1_actions@1"
        },
        {
          "command": "saropaWorkspace.peekPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/ && !(viewItem =~ /^pinRecipe/)",
          "group": "1_actions@5"
        },
        {
          "command": "saropaWorkspace.runPinLastParams",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == pin",
          "group": "1_actions@6"
        },
        {
          "command": "saropaWorkspace.runPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/ && viewItem != pinRunning && viewItem != pinStopping && !(viewItem =~ /Scheduled$/)",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.runPinNow",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /Scheduled$/",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.stopPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem == pinRunning",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.forceKillPin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pinRunning || viewItem == pinStopping)",
          "group": "1_actions@2"
        },
        {
          "command": "saropaWorkspace.showOutput",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "1_actions@3"
        },
        {
          "command": "saropaWorkspace.simulateRun",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "1_actions@4"
        },
        {
          "command": "saropaWorkspace.diffLastRuns",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "1_actions@7"
        },
        {
          "command": "saropaWorkspace.configureRun",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pin || viewItem == pinScheduled)",
          "group": "2_edit@1"
        },
        {
          "command": "saropaWorkspace.configureSchedule",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pin || viewItem == pinScheduled)",
          "group": "2_edit@2"
        },
        {
          "command": "saropaWorkspace.configureTriggers",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pin || viewItem == pinScheduled)",
          "group": "2_edit@3"
        },
        {
          "command": "saropaWorkspace.configureAppearance",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pin || viewItem == pinScheduled)",
          "group": "2_edit@4"
        },
        {
          "command": "saropaWorkspace.renamePin",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "2_edit@4"
        },
        {
          "command": "saropaWorkspace.useAsTemplate",
          "when": "view == saropaWorkspace.pins && (viewItem == pin || viewItem == pinAuto)",
          "group": "2_edit@5"
        },
        {
          "command": "saropaWorkspace.toggleTail",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && (viewItem == pin || viewItem == pinAuto || viewItem == pinScheduled)",
          "group": "2_edit@7"
        },
        {
          "command": "saropaWorkspace.copyPath",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "3_copy@1"
        },
        {
          "command": "saropaWorkspace.copyPinLink",
          "when": "(view == saropaWorkspace.pins || view == saropaWorkspace.recipes) && viewItem =~ /^pin/",
          "group": "3_copy@2"
        },
        {
          "submenu": "saropaWorkspace.pinSubmenu",
          "when": "(view == saropaWorkspace.pins && viewItem =~ /^pin/ && !(viewItem =~ /^pinRecipe/)) || (view == saropaWorkspace.projectFiles && viewItem =~ /^projectFile/)",
          "group": "2_edit@6"
        },
        {
          "command": "saropaWorkspace.addProjectPin",
          "when": "view == saropaWorkspace.projectFiles && viewItem == projectFile",
          "group": "inline@0"
        },
        {
          "command": "saropaWorkspace.removeProjectPin",
          "when": "view == saropaWorkspace.projectFiles && viewItem == projectFilePinned",
          "group": "inline@0"
        },
        {
          "command": "saropaWorkspace.copyPath",
          "when": "view == saropaWorkspace.projectFiles && viewItem =~ /^projectFile/",
          "group": "inline@1"
        },
        {
          "command": "saropaWorkspace.copyPath",
          "when": "view == saropaWorkspace.projectFiles && viewItem =~ /^projectFile/",
          "group": "2_copy@1"
        }
      ],
      "explorer/context": [
        {
          "submenu": "saropaWorkspace.pinSubmenu",
          "group": "saropa@1"
        }
      ],
      "editor/title/context": [
        {
          "submenu": "saropaWorkspace.pinSubmenu",
          "group": "saropa@1"
        }
      ],
      "editor/context": [
        {
          "submenu": "saropaWorkspace.pinSubmenu",
          "group": "saropa@1"
        },
        {
          "command": "saropaWorkspace.pinToLine",
          "when": "editorTextFocus",
          "group": "saropa@2"
        }
      ],
      "commandPalette": [
        {
