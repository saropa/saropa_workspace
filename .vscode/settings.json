{
  // Pin the Python interpreter for the release toolchain (scripts/publish.py).
  // Without this, the Python extension falls back to a global selection that can
  // point at a removed/invalid path, disabling IntelliSense and linting. 3.13 is
  // chosen deliberately: the 3.14 install is reserved for translation/NLLB tools.
  "python.defaultInterpreterPath": "C:\\Users\\craig\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
  // Deeper tree indentation + always-on indent guides so the nested Recipes tree
  // (Recipes -> category folder -> pin) is easy to trace. The default 8px indent
  // makes three levels read as mush; this widens it and draws the vertical guide
  // lines. Window-scoped settings, applied to this workspace.
  "workbench.tree.indent": 30,
  "workbench.tree.renderIndentGuides": "always"
}